#!/bin/bash

check_certificate()
{
    local cert_name="$1"
    local identities=$(security find-identity -v -p codesigning 2>/dev/null)
    [[ $? -ne 0 ]] && return 1 # certificate not found
    printf '%s\n' "$identities" | grep -F -q "$cert_name" # certificate found we send grep output
}

# Cleaning step
echo "# Clean previous dmg in build"
dmgs_found=$(find . -maxdepth 1 -type f -name "*.dmg")
if [[ -n "$dmgs_found" ]]; then
    # We only remove .dmg files
    find . -maxdepth 1 -type f -name "*.dmg" -exec rm -f {} +
fi

# Preparation of the new bundle in TmpInstall
echo "# Prepare the bundle"
BUNDLE="MUSICardio"
cd @PROJECT_BINARY_DIR@
rm -fr TmpInstall
mkdir -p TmpInstall/${BUNDLE}.app/Contents/{MacOS,Resources}
cd TmpInstall

@CMAKE_COMMAND@ -E copy \
    "@medInria_ROOT@/bin/${BUNDLE}.app/Contents/MacOS/${BUNDLE}" \
    "${BUNDLE}.app/Contents/MacOS/"

@CMAKE_COMMAND@ -E copy \
    "@medInria_ROOT@/bin/${BUNDLE}.app/Contents/Info.plist" \
    "${BUNDLE}.app/Contents"

@CMAKE_COMMAND@ -E copy \
    "@medInria_ROOT@/bin/${BUNDLE}.app/Contents/Resources/${BUNDLE}.icns" \
    "${BUNDLE}.app/Contents/Resources"

# Deploy Qt libraries using their tool
echo "# Deploy Qt libs"
@Qt5_DIR@/../../../bin/macdeployqt ${BUNDLE}.app -appstore-compliant

# Run sub-packagers
echo "# Run sub-packager"
injectDirs=''
for i in $*; do
    echo $i
    injectDirs="$injectDirs -inject-dir=$i"
done

mkdir -p python_plugins
injectDirs="$injectDirs -inject-dir=@PROJECT_BINARY_DIR@/TmpInstall/python_plugins"

python_libs=''
for python_lib in @medInria_ROOT@/bin/python_plugins/*; do
    lib=${python_lib##*/}
    libname=${lib%.so}
    @CMAKE_COMMAND@ -E copy "$python_lib" "python_plugins/${libname}.dylib"
    python_libs="$python_libs $libname"
done

# Deploy libs with dtk tool
echo "# DTK Deploy"
@dtk_ROOT@/bin/dtkDeploy ${BUNDLE}.app $injectDirs &>/dev/null

# Correct library paths for plugins, it's needed for the application to find them and also for the signature
echo "# Correct library paths for plugins"
PLUGIN_DIR="${BUNDLE}.app/Contents/PlugIns" 
OLD_PREFIX="@medInria_ROOT@/bin/plugins_legacy" # absolute path
NEW_PREFIX='@executable_path/../PlugIns'        # new relative path
find "$PLUGIN_DIR" -type f -name "*.dylib" | while read -r current_lib; do
    # On each lib in plugins directory we check the dependencies
    otool -L "$current_lib" 2>/dev/null | tail -n +2 | while read -r line; do
        dependency_path=$(echo "$line" | awk '{print $1}')

        [[ "$dependency_path" != /* ]] && continue             # no need to change the path if the actual path is relative
        [[ "$dependency_path" != "$OLD_PREFIX"* ]] && continue # or if the path links to the system 

        new_path="${NEW_PREFIX}/$(basename "$dependency_path")"
        echo "New path: $new_path"
        install_name_tool -change "$dependency_path" "$new_path" "$current_lib"
    done
done

# Python libs preparation
echo "# Installation of Python libraries"
mkdir -p ${BUNDLE}.app/Contents/PlugIns/python
if [ -n "${python_libs}" ]
then
    for python_lib in $python_libs; do
        mv ${BUNDLE}.app/Contents/PlugIns/$python_lib.dylib ${BUNDLE}.app/Contents/PlugIns/python/$python_lib.so
    done
fi

@CMAKE_COMMAND@ --install @pyncpp_ROOT@ --prefix . --component Runtime

mkdir -p ${BUNDLE}.app/Contents/Resources/lib
mv lib/python@PYTHON_VERSION_MAJOR@.@PYTHON_VERSION_MINOR@ ${BUNDLE}.app/Contents/Resources/lib

# Sign the app
if check_certificate "$CERT_NAME"; then
    echo "# Sign the app"
    CERT_NAME="MDS-certificate"
    find "${BUNDLE}.app/Contents/PlugIns" -type f -name "*.dylib" -exec \
        codesign --force --options runtime --timestamp --sign "$CERT_NAME" {} \;

    find "${BUNDLE}.app/Contents/PlugIns/python" -type f -name "*.so" -exec \
        codesign --force --options runtime --timestamp --sign "$CERT_NAME" {} \;

    find "${BUNDLE}.app/Contents/Frameworks" -type d -name "*.framework" -exec \
        codesign --force --options runtime --timestamp --sign "$CERT_NAME" {} \;

    find "${BUNDLE}.app/Contents/Frameworks" -type f -name "*.dylib" -exec \
        codesign --force --options runtime --timestamp --sign "$CERT_NAME" {} \;

    codesign --force --options runtime --timestamp --sign "$CERT_NAME" "${BUNDLE}.app/Contents/MacOS/${BUNDLE}"
    codesign --force --deep --options runtime --timestamp --sign "$CERT_NAME" "${BUNDLE}.app"
    codesign --verify --deep --strict --verbose=1 ${BUNDLE}.app
else
    echo "# No certificate found for the application, we do not sign it"
fi

# Create the DMG
echo "# Create the DMG"
# To install: /usr/bin/python3 -m pip install --user dmgbuild
DMG_NAME="${BUNDLE}-@MEDINRIA_SUPERBUILD_VERSION@.dmg"
/usr/bin/python3 -m dmgbuild \
    -s "../../../packaging/apple/settings.json" \
    "${BUNDLE}" \
    "${DMG_NAME}"

# Sign the DMG
echo "# Sign the DMG"
codesign --sign "${CERT_NAME}" --timestamp --options runtime "${DMG_NAME}"

mv "${DMG_NAME}" @CMAKE_BINARY_DIR@/
