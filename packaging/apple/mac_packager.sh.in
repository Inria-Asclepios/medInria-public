#!/bin/bash

cd @PROJECT_BINARY_DIR@

# Prepare temporary directory
rm -fr TmpInstall
mkdir -p TmpInstall/MUSICardio.app/Contents/Resources

@CMAKE_COMMAND@ -E copy_directory \
    "@medInria_ROOT@/bin/MUSICardio.app/Contents/MacOS" \
    "TmpInstall/MUSICardio.app/Contents"

@CMAKE_COMMAND@ -E copy \
    "@medInria_ROOT@/bin/MUSICardio.app/Contents/Info.plist" \
    "TmpInstall/MUSICardio.app/Contents"

@CMAKE_COMMAND@ -E copy \
    "@medInria_ROOT@/bin/MUSICardio.app/Contents/Resources/MUSICardio.icns" \
    "TmpInstall/MUSICardio.app/Contents/Resources"

cd TmpInstall

@Qt5_DIR@/../../../bin/macdeployqt MUSICardio.app -appstore-compliant

# Run sub-packagers
injectDirs=''
for i in $*; do
        echo $i
        injectDirs="$injectDirs -inject-dir=$i"
done

mkdir python_plugins
injectDirs="$injectDirs -inject-dir=@PROJECT_BINARY_DIR@/TmpInstall/python_plugins"

python_libs=''
for python_lib in @medInria_ROOT@/bin/python_plugins/*; do
    lib=${python_lib##*/}
    libname=${lib%.so}
    @CMAKE_COMMAND@ -E copy "$python_lib" "python_plugins/${libname}.dylib"
    python_libs="$python_libs $libname"
done

@dtk_ROOT@/bin/dtkDeploy MUSICardio.app $injectDirs &>/dev/null

mkdir MUSICardio.app/Contents/Plugins/python
if [ -n "${python_libs}" ]
then
    for python_lib in $python_libs; do
        mv MUSICardio.app/Contents/Plugins/$python_lib.dylib MUSICardio.app/Contents/Plugins/python/$python_lib.so
    done
fi

@CMAKE_COMMAND@ --install @pyncpp_ROOT@ --prefix . --component Runtime
mkdir MUSICardio.app/Contents/Resources/lib
mv lib/python@PYTHON_VERSION_MAJOR@.@PYTHON_VERSION_MINOR@ MUSICardio.app/Contents/Resources/lib

# Keep an .app for signature
@CMAKE_COMMAND@ -E copy_directory "MUSICardio.app" "@CMAKE_BINARY_DIR@"

# Prepare the original sparseimage
@CMAKE_COMMAND@ -E copy \
    "@medInria_SOURCE_DIR@/utils/osx_packaging/BaseMedinriaPackage.sparseimage.gz" \
    "@PROJECT_BINARY_DIR@/MedinriaPackage.sparseimage.gz"

cd @PROJECT_BINARY_DIR@
gunzip -f MedinriaPackage.sparseimage.gz

# Sometimes it's needed after a compilation bug to detach the previous volumes
hdiutil detach "/Volumes/medInria base" 2>/dev/null || true
hdiutil detach "/Volumes/MUSICardio"    2>/dev/null || true

# Attach disk in RW mode
attach_output=$(hdiutil attach -readwrite -noverify -noautoopen MedinriaPackage.sparseimage)
devName=$(echo "$attach_output" | awk '$1 ~ "^/dev/" {print $1; exit}')

# Rename the volume
diskutil rename "medInria base" "MUSICardio"

# Copying
echo "### Copying the app into the mounted volume..."
@CMAKE_COMMAND@ -E copy_directory \
    "@PROJECT_BINARY_DIR@/TmpInstall/MUSICardio.app" \
    "/Volumes/MUSICardio"

sync
hdiutil detach $devName

# Convert the sparseimage into final DMG
hdiutil convert MedinriaPackage.sparseimage -format UDZO -imagekey zlib-level=9 -o "MUSICardio-@MEDINRIA_SUPERBUILD_VERSION@.dmg" 1>/dev/null 2>/dev/null
rm -fr MedinriaPackage.sparseimage @PROJECT_BINARY_DIR@/TmpInstall
mv MUSICardio-@MEDINRIA_SUPERBUILD_VERSION@.dmg @CMAKE_BINARY_DIR@
