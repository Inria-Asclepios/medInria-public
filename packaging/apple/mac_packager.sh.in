#!/bin/bash

check_certificate()
{
    local certificate_name="$1"
    local identities=$(security find-identity -v -p codesigning 2>/dev/null) || return 1 # either the identity succeeds or we return an error code
    printf '%s\n' "$identities" | grep -F -q "$certificate_name" # certificate found we send grep output
}

# Cleaning step
echo "# Clean previous dmg in build"
dmgs_found=$(find . -maxdepth 1 -type f -name "*.dmg")
if [[ -n "$dmgs_found" ]]; then
    # We only remove .dmg files
    find . -maxdepth 1 -type f -name "*.dmg" -exec rm -f {} +
fi

# Preparation of the new bundle in TmpInstall
echo "# Prepare the bundle"
BUNDLE="MUSICardio"
APP_EXE="${BUNDLE}.app/Contents/MacOS/${BUNDLE}"
PLUGIN_DIR="${BUNDLE}.app/Contents/PlugIns"
FRAMEWORK_DIR="${BUNDLE}.app/Contents/Frameworks"
CERT_NAME="MDS-certificate"
QT_VERSION="5"

cd @PROJECT_BINARY_DIR@
rm -fr TmpInstall
mkdir -p TmpInstall/${BUNDLE}.app/Contents/{MacOS,Resources,Frameworks}
cd TmpInstall

@CMAKE_COMMAND@ -E copy \
    "@medInria_ROOT@/bin/${BUNDLE}.app/Contents/MacOS/${BUNDLE}" \
    "${BUNDLE}.app/Contents/MacOS/"

@CMAKE_COMMAND@ -E copy \
    "@medInria_ROOT@/bin/${BUNDLE}.app/Contents/Info.plist" \
    "${BUNDLE}.app/Contents"

@CMAKE_COMMAND@ -E copy \
    "@medInria_ROOT@/bin/${BUNDLE}.app/Contents/Resources/${BUNDLE}.icns" \
    "${BUNDLE}.app/Contents/Resources"

# echo "# Configuration of RPATH"
install_name_tool -add_rpath "@executable_path/../Frameworks" "$APP_EXE"
install_name_tool -add_rpath "@executable_path/../PlugIns" "$APP_EXE"

echo "# Copy ZLIB library"
# find "@ZLIB_ROOT@/lib" -type f -name "libz*.dylib" -exec @CMAKE_COMMAND@ -E copy {} "${FRAMEWORK_DIR}" \;
# ZLIB_LIBS=$(find "${FRAMEWORK_DIR}" -name "libz*.dylib" -type f)
# for zlib_lib in $ZLIB_LIBS; do
#     # Correct id
#     install_name_tool -id "@executable_path/../Frameworks/$(basename "$zlib_lib")" "$zlib_lib"
    
#     # Correct internal dependencies
#     otool -L "$zlib_lib" | tail -n +2 | while read -r line; do
#         dep=$(echo "$line" | awk '{print $1}')
#         if [[ "$dep" == "@rpath/libz."* ]]; then
#             new_name="@executable_path/../Frameworks/$(basename "$dep")"
#             install_name_tool -change "$dep" "$new_name" "$zlib_lib"
#         fi
#     done
# done
# No need to correct lib id and dependence with rsync. Copy real files and symbolic links
rsync -av --links --no-relative \
        --include="libz*.dylib" \
        --exclude="*" \
        "@ZLIB_ROOT@/lib/" "${FRAMEWORK_DIR}/" 2>/dev/null

echo "# Copy DCMTK libraries"
rsync -av --links --no-relative "@DCMTK_ROOT@/lib/" "${FRAMEWORK_DIR}/" 2>/dev/null

# Copy QWT non-CMake library
echo "# Copy QWT framework"
rsync -av --links --no-relative "@qwt_ROOT@/lib/qwt.framework/" "${FRAMEWORK_DIR}/qwt.framework/" 2>/dev/null

# QWT_DIR="${FRAMEWORK_DIR}/qwt.framework"
# QWT_VERSION="6"
# mkdir -p "${QWT_DIR}"
# @CMAKE_COMMAND@ -E copy_directory "@qwt_ROOT@/lib/qwt.framework" "${QWT_DIR}"
# # Qwt bundle format is ambiguous we need to clarify it for signature
# rm -fr ${QWT_DIR}/Headers
# rm -fr ${QWT_DIR}/Resources
# rm -fr ${QWT_DIR}/Versions/Current
# rm ${QWT_DIR}/qwt

# @CMAKE_COMMAND@ -E create_symlink "Versions/$QWT_VERSION/Headers"   "${QWT_DIR}/Headers"
# @CMAKE_COMMAND@ -E create_symlink "Versions/$QWT_VERSION/Resources" "${QWT_DIR}/Resources"
# #@CMAKE_COMMAND@ -E create_symlink "$QWT_VERSION"                    "${QWT_DIR}/Versions/Current"
# ln -sfh "$QWT_VERSION" "${QWT_DIR}/Versions/Current" # error sometimes Current is a directory with the cmake command
# @CMAKE_COMMAND@ -E create_symlink "Versions/$QWT_VERSION/qwt"       "${QWT_DIR}/qwt"

# find "${QWT_DIR}" -name '.*' -type f -exec rm -f {} \; # remove hidden files
# chmod -R 755 "${QWT_DIR}/Versions/$QWT_VERSION"
# chmod 755 "${QWT_DIR}"

# Correct Qwt framework dependencies
# QT_BASE_PATH=$(dirname "$(dirname "@Qt5_DIR@")")
# QWT_BINARY="${QWT_DIR}/Versions/$QWT_VERSION/qwt"
# echo "Qt5_DIR = @Qt5_DIR@"
# echo "QT_BASE_PATH = $QT_BASE_PATH"
# echo "QWT_BINARY = $QWT_BINARY"
# for qt_lib in QtCore QtGui QtWidgets QtPrintSupport QtSvg QtOpenGL QtConcurrent; do
#     OLD_PATH="${QT_BASE_PATH}/${qt_lib}.framework/Versions/$QT_VERSION/${qt_lib}"
#     NEW_PATH="@executable_path/../Frameworks/${qt_lib}.framework/Versions/$QT_VERSION/${qt_lib}"

#     if otool -L "$QWT_BINARY" | grep -q "$OLD_PATH"; then
#         echo "Changing: $OLD_PATH -> $NEW_PATH"
#         install_name_tool -change "$OLD_PATH" "$NEW_PATH" "$QWT_BINARY"
#     fi
# done

# Deploy Qt libraries using their tool
echo "# Deploy Qt libs"
@Qt5_DIR@/../../../bin/macdeployqt ${BUNDLE}.app -appstore-compliant

# Correction needed for Qt5 installed via homebrew, macdeployqt fails to fix Qt plugin dependencies
echo "# Correct Qt plugin dependencies"
find "${BUNDLE}.app/Contents/PlugIns" -name "*.dylib" | while read plugin; do
    old_id=$(otool -D "$plugin" 2>/dev/null | tail -n +2)

    plugin_dir=$(basename $(dirname "$plugin"))
    plugin_name=$(basename "$plugin")
    new_id="@executable_path/../PlugIns/$plugin_dir/$plugin_name"
    
    if [[ "$old_id" == "/usr/local/opt/"* ]] || [[ "$old_id" == *"qt@5"* ]]; then
        echo "Correcting ID: $old_id -> $new_id"
        install_name_tool -id "$new_id" "$plugin"
    fi
done

# Qwt needs QtConcurrent.framework module initially not in the core application
echo "# Copy QtConcurrent.framework for Qwt"
QT_CONCURRENT_SOURCE="@Qt5_DIR@/../../../lib/QtConcurrent.framework"
QT_CONCURRENT_DIR="${FRAMEWORK_DIR}/QtConcurrent.framework"
#QT_CONCURRENT_BINARY="${QT_CONCURRENT_DIR}/Versions/$QT_VERSION/QtConcurrent"
rsync -av --links --no-relative "$QT_CONCURRENT_SOURCE/" "$QT_CONCURRENT_DIR/" 2>/dev/null

# mkdir -p "${QT_CONCURRENT_DIR}"
# @CMAKE_COMMAND@ -E copy_directory "$QT_CONCURRENT_SOURCE" "${QT_CONCURRENT_DIR}"

# # QtConcurrent.framework bundle format is ambiguous we need to clarify it for signature
# rm -fr ${QT_CONCURRENT_DIR}/Headers
# rm -fr ${QT_CONCURRENT_DIR}/Resources
# rm -fr ${QT_CONCURRENT_DIR}/Versions/Current
# rm ${QT_CONCURRENT_DIR}/QtConcurrent
# @CMAKE_COMMAND@ -E create_symlink "Versions/$QT_VERSION/Headers"      "${QT_CONCURRENT_DIR}/Headers"
# @CMAKE_COMMAND@ -E create_symlink "Versions/$QT_VERSION/Resources"    "${QT_CONCURRENT_DIR}/Resources"
# @CMAKE_COMMAND@ -E create_symlink "$QT_VERSION"                       "${QT_CONCURRENT_DIR}/Versions/Current"
# @CMAKE_COMMAND@ -E create_symlink "Versions/$QT_VERSION/QtConcurrent" "${QT_CONCURRENT_DIR}/QtConcurrent"
# find "${QT_CONCURRENT_DIR}" -name '.*' -type f -exec rm -f {} \; # remove hidden files
# chmod -R 755 "${QT_CONCURRENT_DIR}/Versions/$QT_VERSION"
# chmod 755 "${QT_CONCURRENT_DIR}"

# echo "Changing id to $QT_CONCURRENT_BINARY"
# install_name_tool -id "@executable_path/../Frameworks/QtConcurrent.framework/Versions/$QT_VERSION/QtConcurrent" "$QT_CONCURRENT_BINARY"

# otool -L "$QT_CONCURRENT_BINARY" | grep QtCore | while read -r line; do
#     dep=$(echo "$line" | awk '{print $1}')
#     if [[ "$dep" != "@rpath"* ]]; then
#         new_dep="@executable_path/../Frameworks/QtCore.framework/Versions/$QT_VERSION/QtCore"
#         echo "Changing: $dep -> $new_dep"
#         install_name_tool -change "$dep" "$new_dep" "$QT_CONCURRENT_BINARY"
#     fi
# done

# Run sub-packagers
echo "# Run sub-packager"
injectDirs=''
for i in $*; do
    echo $i
    injectDirs="$injectDirs -inject-dir=$i"
done

mkdir -p python_plugins
injectDirs="$injectDirs -inject-dir=@PROJECT_BINARY_DIR@/TmpInstall/python_plugins"

python_libs=''
for python_lib in @medInria_ROOT@/bin/python_plugins/*; do
    lib=${python_lib##*/}
    libname=${lib%.so}
    @CMAKE_COMMAND@ -E copy "$python_lib" "python_plugins/${libname}.dylib"
    python_libs="$python_libs $libname"
done

# Deploy libs with dtk tool
echo "# DTK Deploy"
@dtk_ROOT@/bin/dtkDeploy ${BUNDLE}.app $injectDirs &>/dev/null

# Correct library paths, it's needed to load plugins and also for the signature
echo "# Correct library paths for plugins"
OLD_PREFIX="@medInria_ROOT@/bin/plugins_legacy" # absolute path before
NEW_PREFIX='@executable_path/../PlugIns'        # new relative path
find "$PLUGIN_DIR" -type f -name "*.dylib" | while read -r lib; do
    otool -L "$lib" 2>/dev/null | tail -n +2 | while read -r line; do
        dep=$(echo "$line" | awk '{print $1}')

        # Solving libz wrong paths
        if [[ "$dep" == *"/libz."*".dylib" ]] || [[ "$dep" == *"/libz.dylib" ]]; then
            basename_dep=$(basename "$dep")
            new_path="@executable_path/../Frameworks/${basename_dep}"
            install_name_tool -change "$dep" "$new_path" "$lib"
        fi

        # Solving absolute paths in plugins
        if [[ "$dep" == "$OLD_PREFIX"* ]]; then
            new_path="${NEW_PREFIX}/$(basename "$dep")"
            install_name_tool -change "$dep" "$new_path" "$lib"
        fi
    done
done

echo "# Correct libs for zlib dependencies"
ZLIB_FILE=$(find "${FRAMEWORK_DIR}" -name "libz*.dylib" -type f | head -1)
ZLIB_NAME=$(basename "$ZLIB_FILE")
OUR_ZLIB="@executable_path/../Frameworks/${ZLIB_NAME}"
cd "${FRAMEWORK_DIR}"
ln -sf "$ZLIB_NAME" "libz.1.dylib"
cd @PROJECT_BINARY_DIR@/TmpInstall

# Search all libs finishing with dylib, or begining by Qt but not finishing with dylib (as for Qt bundles) 
find "$FRAMEWORK_DIR" -type f \( -name "*.dylib" -o -name "Qt*" ! -name "*.dylib" \) | while read -r dylib; do
    if [[ "$(basename "$dylib")" == libz* ]]; then
        continue
    fi
    # Searching all lines in current lib with "libz" in it
    otool -L "$dylib" 2>/dev/null | grep libz | while read -r line; do
        bad_path=$(echo "$line" | awk '{print $1}')
        if [[ "$bad_path" != "$OUR_ZLIB" ]] && [[ "$bad_path" != "@executable_path"* ]]; then
            echo "Correcting: $bad_path -> $OUR_ZLIB"
            install_name_tool -change "$bad_path" "$OUR_ZLIB" "$dylib" 2>/dev/null || true
        fi
    done
done

# Python libs preparation
echo "# Installation of Python libraries"
mkdir -p ${BUNDLE}.app/Contents/PlugIns/python
if [ -n "${python_libs}" ]
then
    for python_lib in $python_libs; do
        mv ${BUNDLE}.app/Contents/PlugIns/$python_lib.dylib ${BUNDLE}.app/Contents/PlugIns/python/$python_lib.so
    done
fi

@CMAKE_COMMAND@ --install @pyncpp_ROOT@ --prefix . --component Runtime &>/dev/null

mkdir -p ${BUNDLE}.app/Contents/Resources/lib
mv lib/python@PYTHON_VERSION_MAJOR@.@PYTHON_VERSION_MINOR@ ${BUNDLE}.app/Contents/Resources/lib

# Sign the app
if check_certificate "$CERT_NAME"; then
    echo "# Sign the app"

    # Sign framework libs
    find "$FRAMEWORK_DIR" -type f -name "*.dylib" -exec \
        codesign --force --timestamp --sign "$CERT_NAME" --options runtime {} \;

    # Sign Qwt framework
    codesign --force --timestamp --sign "$CERT_NAME" --options runtime --verbose "${QWT_DIR}/Versions/6/qwt"
    codesign --force --timestamp --sign "$CERT_NAME" --verbose "${QWT_DIR}/Versions/$QWT_VERSION"
    codesign --force --timestamp --sign "$CERT_NAME" --options runtime --verbose "${QWT_DIR}"
    codesign --verify --deep --strict --verbose=2 "${QWT_DIR}"
    spctl -a -vv "${QWT_DIR}"

    # Sign Qt frameworks
    find "$FRAMEWORK_DIR" -name "*.framework" -type d | while read -r framework; do
        echo "Signing $(basename "$framework")"

        # binary
        framework_binary="${framework}/$(basename "$framework" .framework)"
        if [[ -f "$framework_binary" ]]; then
            codesign --force --timestamp --sign "$CERT_NAME" --options runtime --verbose "$framework_binary"
        fi

        # versions
        find "$framework/Versions" -type f -name "$(basename "$framework" .framework)" 2>/dev/null | while read -r version_binary; do
            codesign --force --timestamp --sign "$CERT_NAME" --options runtime --verbose "$version_binary"
        done

        # sign the framework
        codesign --force --timestamp --sign "$CERT_NAME" --verbose "$framework"
    done

    # Sign plugins
    find "$PLUGIN_DIR" -type f \( -name "*.dylib" -o -name "*.so" \) -exec \
        codesign --force --timestamp --sign "$CERT_NAME" {} \;

    # Sign the executable and the full application
    codesign --force --timestamp --sign "$CERT_NAME" "$APP_EXE"
    codesign --force --deep --timestamp --sign "$CERT_NAME" "${BUNDLE}.app"

    # Check
    echo "# Check the signature"
    codesign --verify --deep --strict --verbose=2 "${BUNDLE}.app"
    spctl -a -vv "${BUNDLE}.app"
else
    echo "# No certificate found for the application, we do not sign it"
fi

# Create the DMG
echo "# Create the DMG"
DMG_NAME="${BUNDLE}-@MEDINRIA_SUPERBUILD_VERSION@.dmg"
dmgbuild -s "../../../packaging/apple/settings.json" "${BUNDLE}" "${DMG_NAME}"

# Sign the DMG
if check_certificate "$CERT_NAME"; then
    echo "# Sign the DMG"
    codesign --sign "${CERT_NAME}" --timestamp --options runtime "${DMG_NAME}"
fi

mv "${DMG_NAME}" @CMAKE_BINARY_DIR@/
